{
  "scan_roots": ["ui", "tests", "scripts"],
  "scan_files": [
    "trip_repository.py",
    "trip_crud.py",
    "location_geology.py",
    "finds_collection_events.py",
    "migrations_schema.py"
  ],
  "scan_globs": ["repository_*.py"],
  "rules": [
    {
      "name": "ui",
      "match": {
        "path_prefixes": ["ui/"]
      },
      "forbidden_import_prefixes": [
        "db_bootstrap",
        "db_schema_helpers",
        "db_migration_helpers",
        "scripts.db_bootstrap",
        "scripts.db_schema_helpers",
        "scripts.db_migration_helpers",
        "repository_base",
        "repository_migrations",
        "repository_trip_user",
        "repository_location",
        "repository_finds",
        "repository_geology_schema",
        "repository_geology_data",
        "trip_crud",
        "location_geology",
        "finds_collection_events",
        "migrations_schema"
      ],
      "message": "UI should depend on trip_repository facade, not internal migration/repository modules."
    },
    {
      "name": "repository",
      "match": {
        "path_exact": [
          "trip_repository.py",
          "trip_crud.py",
          "location_geology.py",
          "finds_collection_events.py",
          "migrations_schema.py"
        ],
        "path_globs": ["repository_*.py"]
      },
      "forbidden_import_prefixes": ["ui", "tkinter"],
      "message": "Repository modules must not depend on UI/Tkinter."
    }
  ]
}
