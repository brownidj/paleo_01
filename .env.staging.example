APP_ENV=staging
LOG_LEVEL=INFO

SERVER_HOST=paleo-staging.local
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

POSTGRES_DB=paleo
POSTGRES_USER=paleo
POSTGRES_PASSWORD=replace-with-strong-staging-password

DATABASE_URL=postgresql://paleo:replace-with-strong-staging-password@postgres:5432/paleo

JWT_SECRET=replace-with-staging-jwt-secret
JWT_REFRESH_SECRET=replace-with-staging-refresh-secret
AUTH_USERS_JSON='[{"username":"admin","password":"admin-change-me","role":"admin","display_name":"Staging Admin"}]'
