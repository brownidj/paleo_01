APP_ENV=local
LOG_LEVEL=INFO

SERVER_HOST=localhost
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

POSTGRES_DB=paleo
POSTGRES_USER=paleo
DATABASE_URL=postgresql://paleo:replace-with-strong-password@postgres:5432/paleo

JWT_SECRET=replace-with-very-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-very-long-random-secret
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=qwer1234
BOOTSTRAP_ADMIN_DISPLAY_NAME=Local Admin
