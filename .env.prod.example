APP_ENV=prod
LOG_LEVEL=INFO

SERVER_HOST=api.example.com
ACME_EMAIL=ops@example.com
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

POSTGRES_DB=paleo
POSTGRES_USER=paleo
POSTGRES_PASSWORD=replace-with-strong-production-password

DATABASE_URL=postgresql://paleo:replace-with-strong-production-password@postgres:5432/paleo

JWT_SECRET=replace-with-production-jwt-secret
JWT_REFRESH_SECRET=replace-with-production-refresh-secret
AUTH_USERS_JSON='[{"username":"admin","password":"replace-with-prod-admin-password","role":"admin","display_name":"Production Admin"}]'
